# ==========================================
# Root .gitignore for Unicom_AI (Monorepo)
# ==========================================

# OS/System files
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE & Editor configurations
.vscode/
.idea/
*.suo
*.sln
*.user
*.userosscache
*.sln.docstates

# ==========================================
# 1. Frontend (Vite / React / Node.js)
# ==========================================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/package-lock.json.log
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnpm-debug.log*

# Frontend Local Environment Secrets
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Vite/TS build artifacts
frontend/.svelte-kit/
frontend/.next/
frontend/.nuxt/
frontend/.output/
frontend/tsbuildinfo

# ==========================================
# 2. Backend (Python / FastAPI / MLOps)
# ==========================================
# Byte-compiled / optimized / DLL files
backend/__pycache__/
backend/**/*.py[cod]
backend/*$py.class
backend/**/*.so
backend/**/*.pyd

# Python virtual environments
backend/venv/
backend/env/
backend/.venv/
backend/ENV/
backend/env.bak/
backend/venv.bak/

# Local databases & storage
backend/*.db
backend/launchops.db
backend/app/uploads/*

# ML Model Pickles / Weights
backend/models/*.pkl
backend/app/ml/models/*.pkl
*.pkl

# Python testing/coverage/linting
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/.tox/
backend/.noseids
backend/.mypy_cache/
backend/.ruff_cache/

# ==========================================
# 3. Environment & IDE Tools
# ==========================================
.gemini/
frontend/.tanstack/
